# Public Privy application identifiers from https://dashboard.privy.io/
NEXT_PUBLIC_PRIVY_APP_ID=
NEXT_PUBLIC_PRIVY_CLIENT_ID=

# Temporary UI-only admin allowlist until PostgreSQL + server authorization exist.
# Use comma-separated Privy DIDs, for example: did:privy:abc,did:privy:def
NEXT_PUBLIC_ADMIN_PRIVY_USER_IDS=

# Server-only values. Never prefix these with NEXT_PUBLIC_.
PRIVY_APP_SECRET=

# Server-side admin allowlist (comma-separated Privy DIDs)
ADMIN_PRIVY_USER_IDS=

# PostgreSQL connection string
DATABASE_URL=postgresql://postgres:postgrespassword@localhost:5432/clipfun

# Payout signer private key (platform-owned, NOT a user wallet)
# Generate one with: node -e "console.log('0x'+require('crypto').randomBytes(32).toString('hex'))"
PAYOUT_SIGNER_PRIVATE_KEY=

# CampaignEscrow contract address (after deployment)
NEXT_PUBLIC_CAMPAIGN_ESCROW_ADDRESS=

# Base Sepolia RPC (optional override, default: https://sepolia.base.org)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org
